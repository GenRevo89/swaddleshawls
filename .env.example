# ── Branding (all NEXT_PUBLIC_* are compiled into the client bundle) ──
NEXT_PUBLIC_BRAND_NAME=SwaddleShawls
NEXT_PUBLIC_BRAND_TAGLINE="Pure Comfort from India"
NEXT_PUBLIC_BRAND_DESCRIPTION="Authentic Indian luxury for your little ones — traditional 100% cotton baby shawls, handcrafted with heritage."
NEXT_PUBLIC_BRAND_URL=https://swaddleshawls.com
NEXT_PUBLIC_BRAND_ENTITY="SwaddleShawls"
NEXT_PUBLIC_BRAND_EMAIL=support@swaddleshawls.com
BRAND_CRM_TAG=swaddleshawls
BRAND_FORM_SLUG=contact-form

# ── BasaltSurge Payment Gateway ──
SURGE_API_KEY=sk_live_your_surge_api_key_here
SURGE_MERCHANT_WALLET=0xYourMerchantWalletAddressHere

# ── MongoDB ──
DATABASE_URL="mongodb+srv://user:password@cluster.example.com/crm?replicaSet=replicaset&tls=true&authSource=admin"
MONGODB_CONNECTION_STRING="mongodb+srv://user:password@cluster.example.com/admin?replicaSet=replicaset&tls=true"
DB_NAME=swaddleshawls

# ── S3 / Object Storage ──
STORAGE_PROVIDER=s3
S3_ENDPOINT=https://s3.your-region.example.com/
S3_REGION=us-west-1
S3_BUCKET_NAME=hosted-clients
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key

# ── BasaltCRM ──
BASALT_CRM_KEY=sk_live_your_crm_api_key_here

# ── Debug (set to TRUE to enable debug tools in portal) ──
# TESTING=TRUE
